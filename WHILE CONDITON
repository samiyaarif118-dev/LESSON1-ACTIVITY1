<html>
    <body>
        <h2>JavaScript While Loop</h2>
        <p id="number"></p>
        <script>
            var text = "";
            var i = 0;
            while (i < 10) {
                text += "The number is " + i + "<br>";
                i++;
            }
            document.getElementById("number").innerHTML = text;
        </script>